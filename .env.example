# 纸面交易只读取公开行情，不需要 Bitget API Key。
# 将来启用实盘时再配置，且不要把真实密钥提交到版本库。
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# 安全开关：第一版必须保持 paper / false。
EXECUTION_MODE=paper
LIVE_TRADING_ENABLED=false

# QQ 邮件通知。SMTP_PASSWORD 填 QQ 邮箱授权码，不是 QQ 密码。
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=你的QQ号@qq.com
SMTP_PASSWORD=
ALERT_EMAIL_FROM=你的QQ号@qq.com
ALERT_EMAIL_TO=你的收件邮箱
